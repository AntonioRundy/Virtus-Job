# ─── Database ───────────────────────────────────────────
POSTGRES_USER=virtus
POSTGRES_PASSWORD=virtus_secret
POSTGRES_DB=virtus_job
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://virtus:virtus_secret@postgres:5432/virtus_job

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── API Security ───────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── AI ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Application ────────────────────────────────────────
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
PROJECT_NAME=Virtus Job
API_HOST=0.0.0.0
API_PORT=8000

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Virtus Job
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (future) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@virtusjob.ao

# ─── Jornal de Angola — Assinatura Premium ───────────────
# Credenciais do utilizador com assinatura activa.
# NUNCA commitar valores reais — este ficheiro é apenas o template.
# Copiar para .env e preencher com as credenciais reais.
JDA_EMAIL=seu.email@exemplo.com
JDA_PASSWORD=
# URL de login (ajustar se o site alterar estrutura)
JDA_LOGIN_URL=https://jornaldeangola.ao/login
JDA_BASE_URL=https://jornaldeangola.ao
# Ficheiro de sessão (cookies persistentes — gitignored)
JDA_SESSION_FILE=scrapers/sessions/jda_session.json
