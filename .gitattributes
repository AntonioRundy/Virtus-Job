# Normalizar line endings para LF em todos os ficheiros de texto
* text=auto eol=lf

# Ficheiros que DEVEM ser LF
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sql   text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Ficheiros binários — sem conversão
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# PowerShell — CRLF no Windows
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
